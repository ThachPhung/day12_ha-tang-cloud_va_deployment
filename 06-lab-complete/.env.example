HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=English Flashcard API
APP_VERSION=1.0.0

# Flashcard — để DEMO_MODE=true hoặc xóa DATABASE_URL trên Render để chạy không cần Postgres
DEMO_MODE=false
DATABASE_URL=sqlite:///./data/flashcard.db
SECRET_KEY=change-this-in-production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MAX_USERS=5

# Day 12 gateway
AGENT_API_KEY=dev-key-change-me-in-production
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
